# Telegram (required)
BOT_TOKEN=your_telegram_bot_token_here

# Logging: INFO, DEBUG, ... ; LOG_JSON=false for plain text logs locally
# LOG_LEVEL=INFO
# LOG_JSON=true

# SQLite and limits
# DATA_DIR=data
# DAILY_GENERATION_LIMIT=5
# MAX_CAPTION_LENGTH=1024

# Admin user IDs (comma-separated Telegram numeric ids)
# ADMIN_USER_IDS=123456789,987654321

# ProxyAPI.ru — images + Whisper STT (required for cards and voice)
PROXI_API_KEY=your_proxyapi_key
PROXI_BASE_URL=https://openai.api.proxyapi.ru
# PROXI_IMAGE_MODEL=gpt-image-1
# PROXI_IMAGE_TIMEOUT=120
# STT_TIMEOUT=45

# Yandex Cloud Foundation Models — text + prompt refinement (required for captions)
# Create a folder, service account with ai.languageModels.user, API key in console.
YANDEX_API_KEY=your_yandex_api_key
YANDEX_FOLDER_ID=b1gxxxxxxxxxxxxxxxxxxxx
# YANDEX_MODEL_SUFFIX=yandexgpt/latest
# YANDEX_COMPLETION_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/completion
# YANDEX_TIMEOUT=90
# YANDEX_PROMPT_REFINE_TIMEOUT=45
