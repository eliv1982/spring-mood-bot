# Telegram Bot (токен от @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Optional: LOG_LEVEL=DEBUG
# LOG_LEVEL=INFO

# ProxyAPI.ru (генерация изображений) — https://proxyapi.ru/docs/openai-image-generation
# Универсальный API (рекомендуется). Ключ: https://console.proxyapi.ru → Ключи API
PROXI_API_KEY=your_proxyapi_key
PROXI_BASE_URL=https://openai.api.proxyapi.ru

# ---- GigaChat (Сбер) https://developers.sber.ru/ ----
# При ошибке "Can't decode Authorization header" лучше использовать ключ из кабинета (вариант 2).

# Вариант 1: client_id:client_secret (без пробелов и переносов в одной строке)
# GIGACHAT_CREDENTIALS=client_id:client_secret

# Вариант 2 (рекомендуется): скопировать из кабинета поле "Authorization Key" (одна строка Base64)
GIGACHAT_AUTHORIZATION_KEY=

# Scope для физлиц (не менять)
GIGACHAT_SCOPE=GIGACHAT_API_PERS
